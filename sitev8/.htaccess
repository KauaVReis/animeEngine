# ============================================================
# AnimeEngine v8 - .htaccess
# Front Controller + Segurança
# ============================================================

RewriteEngine On

# Base relativa ao diretório sitev8/
RewriteBase /kaua1/2026/animeEngine/sitev8/

# ----- BLOQUEIO DE ACESSO DIRETO À PASTA views/ -----
RewriteRule ^views/ - [F,L]

# ----- FRONT CONTROLLER -----
# Se o arquivo existir fisicamente, serve ele diretamente (CSS, JS, Imagens, etc)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule .? - [L]

# Se o diretório existir fisicamente, serve ele diretamente
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule .? - [L]

# Caso contrário, manda tudo para o index.php
RewriteRule . index.php [L]

# ----- HEADERS HTTP DE SEGURANÇA -----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # CSP: permite self + Google Fonts + Font Awesome CDN + AniList API + YouTube
    Header always set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.youtube.com https://s.ytimg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https://s4.anilist.co https://img.youtube.com https://i.ytimg.com data:; connect-src 'self' https://graphql.anilist.co; frame-src https://www.youtube.com;"
</IfModule>

# ----- DESABILITAR LISTAGEM DE DIRETÓRIOS -----
Options -Indexes
